{
  "name": "@idealyst/pdf",
  "version": "1.3.3",
  "description": "Cross-platform PDF viewer for React and React Native",
  "readme": "README.md",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.native.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/IdealystIO/idealyst-framework.git",
    "directory": "packages/pdf"
  },
  "author": "Idealyst <contact@idealyst.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "echo 'Publishing TypeScript source directly'",
    "publish:npm": "npm publish"
  },
  "peerDependencies": {
    "pdfjs-dist": ">=3.0.0",
    "react": ">=16.8.0",
    "react-native": ">=0.60.0",
    "react-native-blob-util": ">=0.19.0",
    "react-native-pdf": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-blob-util": {
      "optional": true
    },
    "react-native-pdf": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "pdfjs-dist": "^4.0.0",
    "react": "^19.1.0",
    "react-native": "^0.80.1",
    "react-native-blob-util": "^0.19.0",
    "react-native-pdf": "^6.7.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "react",
    "react-native",
    "pdf",
    "viewer",
    "document",
    "cross-platform",
    "pdfjs"
  ]
}
